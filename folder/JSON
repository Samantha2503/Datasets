import cv2
import numpy as np
import json
from segment_anything import sam_model_registry, SamAutomaticMaskGenerator
import os

# Configuración
MODEL_PATH = "sam_vit_b.pth"
MIN_MASK_AREA = 1000
input_folder = "dataset_raw/images"
output_json_folder = "dataset_raw/annotations"

os.makedirs(output_json_folder, exist_ok=True)

# Cargar modelo SAM
sam = sam_model_registry["vit_b"](checkpoint=MODEL_PATH)
mask_generator = SamAutomaticMaskGenerator(
    sam,
    pred_iou_thresh=0.8,
    stability_score_thresh=0.85,
    min_mask_region_area=MIN_MASK_AREA
)

def mask_to_json(mask, label, image_shape):
    h, w = image_shape
    # extraer contorno
    contours, _ = cv2.findContours(mask.astype(np.uint8), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)
    polygons = [cnt.squeeze().tolist() for cnt in contours if cnt.shape[0] > 2]
    shapes = []
    for poly in polygons:
        shapes.append({"label": label, "points": poly, "shape_type": "polygon", "flags": {}})
    return shapes

# Procesar imágenes
for img_file in os.listdir(input_folder):
    if not img_file.endswith(".jpg"):
        continue
    img_path = os.path.join(input_folder, img_file)
    img = cv2.imread(img_path)
    img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

    masks = mask_generator.generate(img_rgb)
    shapes = []

    for i, m in enumerate(masks):
        mask = m['segmentation'].astype(np.uint8)
        # Filtrado por área y limpieza
        if mask.sum() < MIN_MASK_AREA:
            continue
        mask = cv2.morphologyEx(mask, cv2.MORPH_CLOSE, np.ones((5,5),np.uint8))
        # Asignar label automático: tornillo si ratio alto, placa si más cuadrado
        y,x = np.where(mask)
        h_mask = y.max()-y.min()
        w_mask = x.max()-x.min()
        ratio = max(h_mask/w_mask, w_mask/h_mask)
        label = "tornillo" if ratio > 2.5 else "placa"

        shapes += mask_to_json(mask, label, img.shape[:2])

    # Guardar JSON
    json_data = {
        "version": "1.0",
        "flags": {},
        "shapes": shapes,
        "imagePath": img_file,
        "imageHeight": img.shape[0],
        "imageWidth": img.shape[1]
    }
    with open(os.path.join(output_json_folder, img_file.replace(".jpg",".json")), "w") as f:
        json.dump(json_data, f, indent=2)
    print(f"{img_file} → {len(shapes)} máscaras generadas")
